<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_weekly_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg_dark"
    android:gravity="center_vertical">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 This Week"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#00C853"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Total hours — big number -->
    <TextView
        android:id="@+id/tv_total_hours"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0h"
        android:textColor="#F5F5F5"
        android:textSize="28sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="4dp" />

    <!-- 7-day bar chart (7 ImageView bars) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="bottom|center_horizontal"
        android:layout_marginTop="10dp">

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_mon" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Monday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_tue" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Tuesday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_wed" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Wednesday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_thu" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Thursday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_fri" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Friday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_sat" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Saturday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:padding="2dp">
            <ImageView android:id="@+id/bar_sun" android:layout_width="match_parent" android:layout_height="4dp" android:layout_gravity="bottom" android:src="@drawable/widget_bar_bg" android:scaleType="fitXY" android:contentDescription="Sunday" />
        </FrameLayout>
    </LinearLayout>

    <!-- Day labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="M" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="W" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="F" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textColor="#707070" android:textSize="9sp" android:gravity="center" />
    </LinearLayout>

    <!-- Bottom row: streak + sessions count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tv_streak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔥 0 day streak"
            android:textColor="#707070"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_sessions_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 sessions"
            android:textColor="#707070"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
